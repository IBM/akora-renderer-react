{
  "parser": "@babel/eslint-parser",
  "parserOptions": {
    "requireConfigFile" : "false",
    "babelOptions": {
      "configFile": "./.babelrc.js"
    }
  },
  "env": {
    "jest": true
  },
  "plugins": ["notice"],
  "rules": {
    "notice/notice": [
      "error",
      {
        "templateFile":"config/copyright.js"
      }
    ]
  }
}
